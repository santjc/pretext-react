{
  "name": "@santjc/react-pretext",
  "version": "0.0.1",
  "description": "Thin React primitives and re-exports for @chenglou/pretext.",
  "license": "MIT",
  "type": "module",
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "sideEffects": false,
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./experimental": {
      "types": "./dist/experimental.d.ts",
      "import": "./dist/experimental.js"
    }
  },
  "files": [
    "dist"
  ],
  "publishConfig": {
    "access": "public"
  },
  "keywords": [
    "react",
    "pretext",
    "text-measurement",
    "typography",
    "layout"
  ],
  "scripts": {
    "build": "tsup src/index.ts src/experimental.ts --format esm --dts",
    "lint": "eslint src",
    "test": "vitest run --config vitest.config.ts"
  },
  "peerDependencies": {
    "react": "^19.0.0",
    "react-dom": "^19.0.0"
  },
  "dependencies": {
    "@chenglou/pretext": "^0.0.3"
  }
}
